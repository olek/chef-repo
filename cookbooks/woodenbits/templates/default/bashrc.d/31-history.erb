# echo "Attempting to reset history settings"

HISTCONTROL=ignorespace:ignoredups #:erasedups
HISTIGNORE="l:ll:la:lla:pwd:isp:cr"
HISTSIZE=100000
HISTFILESIZE=200000

# do not override history file with "newer" history!
# append instead of rewrite
shopt -s histappend

# save history after every command to avoid losing it on crashes
# and to make it instantly accessible in other terminals
# Not preserving original PROMPT_COMMAND to avoid somehow repeating same thing over and over
# Disabled this mode because somehow all my old history goes the way of dodo
# export PROMPT_COMMAND="history -a"
# __short_dir is consumed by PS1 in 20-prompt. We compute it here (rather than
# inside PS1 itself) so readline sees a static prompt string and doesn't lose
# track of the cursor column on long directory names. Keep this assignment in
# PROMPT_COMMAND so it runs once per prompt.
<%- if @is_root -%>
PROMPT_COMMAND='__short_dir=$(short_dir)'
<%- else -%>
PROMPT_COMMAND='__short_dir=$(short_dir); echo "$(date "+%Y-%m-%d.%H:%M:%S") $(pwd) $(history 1)" >> ~/.bash_history.d/$(date "+%Y-%m-%d").log'
<%- end -%>
