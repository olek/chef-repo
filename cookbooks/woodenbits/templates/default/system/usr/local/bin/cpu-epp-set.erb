#!/usr/bin/env bash
set -e
set -o pipefail

# Runs command with custom energy performance preference, then reverts in back.
# Requires cpu.epp.set.policy file to grant root permissions to this script

epp_value=$1

if [[ -z $epp_value ]]; then
  echo "No epp_value specified, exiting"
  exit 1
fi

for i in /sys/devices/system/cpu/cpufreq/policy[0-9]*/energy_performance_preference; do
  echo "$epp_value" > "$i" || true;
done

