#!/usr/bin/env bash
set -e
set -o pipefail

# Runs other command on increased CPU speed

command=$1

if [[ -z $command ]]; then
  echo "No command specified, exiting"
  exit 1
fi

# trap ctrl-c and call ctrl_c()
trap ctrl_c INT

function ctrl_c() {
  pkexec cpu-epp-set power
}

declare -r previous_epp=$(cpu-epp-show | head -n1 | awk 'NF>1{print $NF}')

pkexec cpu-epp-set performance
timed "$@"
pkexec cpu-epp-set "$previous_epp"

