#!/usr/bin/env bash

# Document commands useful for wrangling nvidia or general power consumption here
#
# * watching nvidia gpu runtime status (active/suspended)
#     watch --interval 5 cat /sys/bus/pci/devices/0000\:01\:00.0/power/runtime_status
#
# * checking on availability/kind of runtime D3 status (d3cold)
#     cat /proc/driver/nvidia/gpus/0000:01:00.0/power
#
# * regenerating ramfs after changing nvidia etc module configuration
#     update-initramfs -u
#
# * regenerating grub setup after changing its config
#     update-initramfs -u
#
# * setting up limiters on nvidia clocks to force it into economy mode
#     nvidia-smi --persistence-mode=1
#     nvidia-smi --lock-gpu-clocks=300,300
#
#     # not supported for Quadro T1000
#     # nvidia-smi --lock-memory-clocks=810,810
#
#     nvidia-smi --application-clocks=810,300
#
# * configuring nvidia gpu for fine grained runtime D3 status in /etc/modprobe.d/nvidia-custom.conf
#     # Work around broken D3 support in pre-ampere (turing) architecture.
#     # Requires using closed source nvidia driver (nvidia-open does not seem to support rtd3 on turing at all).
#     options nvidia "NVreg_EnableGpuFirmware=0"
#     # Forcing 0x02 'fine' D3 control that is supported on closed source nvidia driver.
#     options nvidia "NVreg_DynamicPowerManagement=0x02"
#
# * Note: current reverse-prime configuration on severus requires a reboot after HDMI port was disconnected for nvidia
#   to go to D3Cold state, but NO configuration changes seems to be necessary. And re-plugging HDMI will automatically
#   activate nvidia gpu. Not bad.

set -uo pipefail

readonly NVIDIA_PCI_ADDR="0000:01:00.0"
readonly PCI_SHORT_ADDR="01:00.0"
readonly NVIDIA_GPU_NAME_FILE="/tmp/nvidia-gpu-name.txt"

# Initialize GPU name cache
init_gpu_name() {
  if [[ ! -f "$NVIDIA_GPU_NAME_FILE" ]]; then
    local gpu_name driver_version
    gpu_name=$(lspci 2>/dev/null | grep "^${PCI_SHORT_ADDR}" | sed -e "s/^${PCI_SHORT_ADDR} VGA compatible controller: //")
    driver_version=$(cat /sys/module/nvidia/version 2>/dev/null)
    echo "${gpu_name:-Unknown GPU} / ${driver_version:-Unknown Driver}" > "$NVIDIA_GPU_NAME_FILE"
  fi
}

print_system_info() {
  # 1. Print Time
  printf "Time: \t\t\t%s\n" "$(date | tr -s ' ')"

  # 2. Print Computer Make/Model and CPU Info
  printf "Computer: \t\t"
  if [[ -r /sys/devices/virtual/dmi/id/sys_vendor && -r /sys/devices/virtual/dmi/id/product_family ]]; then
    printf "%s %s " "$(cat /sys/devices/virtual/dmi/id/sys_vendor)" "$(cat /sys/devices/virtual/dmi/id/product_family)"
  else
    printf "Unknown "
  fi

  local cpu_model="Unknown"
  if [[ -r /proc/cpuinfo ]]; then
    cpu_model=$(awk -F': ' '/model name/ {print $2; exit}' /proc/cpuinfo)
  fi
  printf "/ %s\n" "$cpu_model"

  # 3. Print Governor / Preference
  local gov="Unknown" pref="Unknown"
  if [[ -r /sys/devices/system/cpu/cpufreq/policy0/scaling_governor ]]; then
    gov=$(< /sys/devices/system/cpu/cpufreq/policy0/scaling_governor)
  fi
  if [[ -r /sys/devices/system/cpu/cpufreq/policy0/energy_performance_preference ]]; then
    pref=$(< /sys/devices/system/cpu/cpufreq/policy0/energy_performance_preference)
  fi
  printf "Governor / pref: \t%s / %s\n" "$gov" "$pref"

  # 4. Print CPU boost status
  local cpu_boost="Unknown"
  if [[ -r /sys/devices/system/cpu/intel_pstate/no_turbo ]]; then
    cpu_boost=$(< /sys/devices/system/cpu/intel_pstate/no_turbo)
  fi
  printf "CPU boost disabled: \t%s\n" "$cpu_boost"
}

print_cpu_stats() {
  local sensors_data="${1:-}"

  # 5. Print CPU Average Freq and Min/Max
  shopt -s nullglob
  local freq_files=(/sys/devices/system/cpu/cpufreq/policy*/scaling_cur_freq)
  shopt -u nullglob

  if (( ${#freq_files[@]} > 0 )); then
    printf "CPU avg freq: \t\t"
    awk 'BEGIN {sum = 0} { sum += $1 } END { if (NR > 0) printf "%sMHz\n", int(sum / NR / 1000); else printf "N/A\n" }' "${freq_files[@]}"
    
    printf "CPU cnt / frq min,max: \t"
    awk 'NR==1 {min = max = $1} max < $1 { max = $1 } min > $1 { min = $1 } END { if (NR > 0) printf "%s / %sMHz / %sMHz\n", NR, int(min / 1000), int(max / 1000); else printf "N/A\n" }' "${freq_files[@]}"
  else
    printf "CPU avg freq: \t\tN/A\n"
    printf "CPU cnt / frq min,max: \tN/A\n"
  fi

  # 6. Print Core Temperature
  printf "Core temperature: \t"
  if [[ -n "$sensors_data" ]] && command -v jq >/dev/null; then
    local core_temp
    core_temp=$(echo "$sensors_data" | jq --raw-output '."coretemp-isa-0000" | [to_entries | map(select(.key | match("^Core.*";"i"))) | map(.value) | .[] | to_entries | map(select(.key | match(".*_input$";"i"))) | map(.value) | .[]] | add/length | floor | tostring + "°C"' 2>/dev/null)
    printf "%s\n" "${core_temp:-N/A}"
  else
    printf "N/A\n"
  fi
}

print_gpu_stats() {
  local nvidia_runtime_status="${1:-unknown}"

  # 7. Print GPU Temp / State / Power (if active)
  if [[ -x "/usr/bin/nvidia-smi" && "$nvidia_runtime_status" == "active" ]]; then
    local nsmi_data
    nsmi_data=$(nvidia-smi -q 2>/dev/null || true)
    if [[ -n "$nsmi_data" ]]; then
      printf "GPU temp / st / pwr: \t"
      echo "$nsmi_data" | awk '
        /GPU Current Temp/ { temp = $5 }
        /Performance State/ { state = $4 }
        /Instantaneous Power Draw/ { if (!power) power = $5 }
        END { printf "%s / %s / %s\n", (temp ? temp "°C" : "N/A"), (state ? state : "N/A"), (power ? power "W" : "N/A") }
      '
    fi
  fi
}

print_other_temps() {
  local sensors_data="${1:-}"

  # 8. Print Other Temperatures
  if [[ -n "$sensors_data" ]] && command -v jq >/dev/null; then
    printf "Other temps (°C): \t"
    echo "$sensors_data" | jq --raw-output '
      # Shorten long chip names to a couple of letters. First substring match wins;
      # anything unknown falls back to its first word (up to the first separator).
      def shorten:
        [ ["coretemp","core"], ["pch","pch"], ["acpitz","acpi"], ["acpi","acpi"],
          ["iwlwifi","wifi"], ["nvme","nvme"], ["k10temp","cpu"], ["nouveau","gpu"],
          ["amdgpu","gpu"] ] as $map
        | . as $chip
        | ($chip | ascii_downcase) as $lc
        | ([$map[] | . as $p | select($lc | contains($p[0])) | $p[1]] | first)
          // ($chip | split("[-_]"; "") | .[0]);
      [ to_entries[]
        | .key as $chip
        # coretemp is already shown (averaged) on the dedicated Core temperature line.
        | select($chip | ascii_downcase | contains("coretemp") | not)
        | ([.value | to_entries[] | .value | objects | to_entries[]
            | select(.key | test("^temp[0-9]*_input$")) | .value] | first) as $t
        | select($t != null)
        | {key: $chip, label: ($chip | shorten), temp: ($t | floor)} ]
      # Number repeated labels (e.g. two NVMe drives -> nvme1 / nvme2), numbering by
      # original chip key so the suffix is stable. Singletons keep their bare label.
      | ( group_by(.label)
          | map( (sort_by(.key)) as $g
                 | if length > 1
                   then ($g | to_entries | map(.value + {label: (.value.label + (.key + 1 | tostring))}))
                   else $g end )
          | flatten )
      | sort_by(.label)
      | "\([.[].temp | tostring] | join(" / ")) (\([.[].label] | join("/")))"'
  fi
}

print_nvidia_runtime_status() {
  local nvidia_runtime_status="${1:-unknown}"

  # 9. Print Nvidia Runtime status
  local gpu_name="Unknown"
  if [[ -f "$NVIDIA_GPU_NAME_FILE" ]]; then
    gpu_name=$(< "$NVIDIA_GPU_NAME_FILE")
  fi
  printf "Nvidia runtime for:\t%s\n" "$gpu_name"
  printf "  status: \t\t%s\n" "$nvidia_runtime_status"

  # 10. Print D3 allowed / pstate
  local d3_allowed="N/A" power_state="N/A"
  if [[ -r "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/d3cold_allowed" ]]; then
    d3_allowed=$(< "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/d3cold_allowed")
  fi
  if [[ -r "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power_state" ]]; then
    power_state=$(< "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power_state")
  fi
  printf "  D3 allowed / pstate:\t%s / %s\n" "${d3_allowed//[$'\n']/}" "${power_state//[$'\n']/}"

  # 11. Print active / suspended times
  local active_time="N/A" suspended_time="N/A"
  if [[ -r "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_active_time" ]]; then
    active_time=$(< "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_active_time")
  fi
  if [[ -r "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_suspended_time" ]]; then
    suspended_time=$(< "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_suspended_time")
  fi
  printf "  active time: \t\t%s\n" "${active_time//[$'\n']/}"
  printf "  suspended time: \t%s\n" "${suspended_time//[$'\n']/}"
}

print_battery_info() {
  # 12. Print Battery Discharge Info
  if command -v upower >/dev/null; then
    local bat_device
    bat_device=$(upower -e | grep BAT | head -n1)
    if [[ -n "$bat_device" ]]; then
      printf "Battery discharge info as of: "
      upower -i "$bat_device" | grep --color=never -E "updated|state|energy-rate|time to empty" | sed -e 's/ \+updated: \+//'
    else
      printf "Battery discharge info: No battery device found\n"
    fi
  else
    printf "Battery discharge info: upower not installed\n"
  fi
}

print_top_processes() {
  # 13. Top processes by CPU time
  ps -axo pid,pcpu,cputime,etime,comm --cumulative --sort -time | head -n6
}

print_system_load() {
  # 14. Top output (non-interactive batch mode)
  top -b -n 1 | head -n15
}

main() {
  init_gpu_name

  local sensors_data
  sensors_data=$(sensors -A -j 2>/dev/null || true)

  local nvidia_runtime_status="unknown"
  if [[ -r "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_status" ]]; then
    nvidia_runtime_status=$(< "/sys/bus/pci/devices/${NVIDIA_PCI_ADDR}/power/runtime_status")
  fi

  print_system_info
  print_cpu_stats "$sensors_data"
  print_gpu_stats "$nvidia_runtime_status"
  print_other_temps "$sensors_data"

  printf "\n"
  print_nvidia_runtime_status "$nvidia_runtime_status"

  printf "\n"
  print_battery_info

  printf "\n"
  print_top_processes
  
  printf "\n"
  print_system_load
}

main "$@"
