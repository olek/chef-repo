<%-
  if @user == 'opoplavsky'
    kanata_dir = '/data/dev/misc/kanata/kanata-setup'
    chef_dir   = '~/git/chef-repo'
  else
    kanata_dir = '~/git/my/kanata-setup'
    chef_dir   = '~/git/my/chef-repo'
  end
-%>
cd ~

new_session -n root
new_window -n perf-watch
new_window -n ncmpc
new_window -n kanata -c <%= kanata_dir %>
new_window -n chef -c <%= chef_dir %>
new_window -n cmd
#new_window -n cmd2
#new_window -n disks

sleep 1.0

# send_keys disks 'sudo bash -c "watch hdparm -C /dev/sdb /dev/sdc"' 'Enter'
send_keys root 'sudo -H -i' 'Enter'
send_keys perf-watch 'watch --interval 30 perf-watch-cmd' 'Enter'
send_keys ncmpc '#pasuspender ncmpc' 'Enter'

