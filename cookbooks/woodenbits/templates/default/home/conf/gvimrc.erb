" set the X11 font to use
" set guifont=-misc-fixed-medium-r-normal--14-130-75-75-c-70-iso8859-1

set mousehide		" Hide the mouse when typing text

" for Ubuntu, GTK2 GUI
"set gfn=Monospace\ 11
"set guifont=Ubuntu\ Mono\ Regular\ 12
set guifont=Liberation\ Mono\ 11

" Resizing fonts on the fly
let s:pattern = '^\(.* \)\([1-9][0-9]*\)$'
let s:minfontsize = 6
let s:maxfontsize = 16
function! AdjustFontSize(amount)
  if has("gui_gtk2") && has("gui_running")
    let fontname = substitute(&guifont, s:pattern, '\1', '')
    let cursize = substitute(&guifont, s:pattern, '\2', '')
    let newsize = cursize + a:amount
    if (newsize >= s:minfontsize) && (newsize <= s:maxfontsize)
      let newfont = fontname . newsize
      let &guifont = newfont
    endif
  else
    echoerr "You need to run the GTK2 version of Vim to use this function."
  endif
endfunction

function! LargerFont()
  call AdjustFontSize(1)
endfunction
command! LargerFont call LargerFont()

function! SmallerFont()
  call AdjustFontSize(-1)
endfunction
command! SmallerFont call SmallerFont()

" set the gui options to:
"   g: grey inactive menu items
"   m: display menu bar
"   r: display scrollbar on right side of window
"   b: display scrollbar at bottom of window
"   t: enable tearoff menus on Win32
"   T: enable toolbar on Win32
set guioptions-=m  "remove menu bar
set guioptions-=T  "remove toolbar
set guioptions-=r  "remove right-hand scroll bar

<%- if @is_root -%>
color torte
<%- else -%>
color default
<%- end -%>

set background=light

" selected light themes followed by the dark themes on separate line for easier management
silent SetColors
  \ vc minimal lingodirector sienna smpl stackoverflow winter morning bclear chela_light grape habiLight highlighter_term kyle nedit newsprint pleasant summerfruit blueshift
  \ slate 1989 colorsbox-material darktango deus earendel ekinivim moria nefertiti seattle tango-desert void zenburn anotherdark brighton codedark darkZ ecostation feral flattown ghostbuster japanesque lilypink materialtheme mrpink nord obsidian2 parsec Tomorrow-Night-Eighties softblue termschool DimGrey bubblegum corn

" Fallback theme for default, forcing manual choice after restart
colorscheme tomatosoup

highlight WhiteSpaceEOL ctermbg=darkgreen guibg=lightgreen
match WhiteSpaceEOL /^\s\+\t\+\|^\t\+\s\+\|\s\+$/

" Prevents last window from being accidentally closed
if has('macunix')
  macm File.Close key=<nop>
end
nnoremap <silent> <D-w> <Esc>:bd<CR>

" Tab headings & Navigation
" Go to the last active tab, like ctrl-^ but for tabs
augroup gvimrc_tab
  autocmd!
  autocmd TabLeave * let g:lasttab = tabpagenr()
augroup END

nnoremap <silent> <c-tab> :exe "tabn ".g:lasttab<cr>
vnoremap <silent> <c-tab> :exe "tabn ".g:lasttab<cr>

function! GuiTabLabel()
  let label = ''
  let bufnrlist = tabpagebuflist(v:lnum)

  " Add '+' if one of the buffers in the tab page is modified
  for bufnr in bufnrlist
    if getbufvar(bufnr, "&modified")
      let label = '+'
      break
    endif
  endfor

  let label .= v:lnum
  let label .= ' '

  " Get active buffer details
  let active_bufnr = bufnrlist[tabpagewinnr(v:lnum) - 1]
  let project = getbufvar(active_bufnr, 'title', '')

  " Use project name if known, fallback to file name
  if !empty(project)
    let value = project
  else
    let file = bufname(active_bufnr)
    if empty(file)
      let value = 'No Name'
    else
      let value = fnamemodify(file, ':t')
    endif
  endif

  let label .= '[' . value . ']'

  " Append the number of windows in the tab page if more than one
  let wincount = tabpagewinnr(v:lnum, '$')
  if wincount > 1
    let label .= ' (' . wincount . ')'
  endif

  return label
endfunction

" Register autocommand to run after vim-project's VimEnter autocommand has run
augroup gvimrc_guitablabel
  autocmd!
  autocmd VimEnter * set guitablabel=%!GuiTabLabel()
augroup END

let s:gvimrc_after_local = expand($HOME . '/.gvimrc.after')
if filereadable(s:gvimrc_after_local)
  exec ':so ' . s:gvimrc_after_local
endif


