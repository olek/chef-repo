#!/usr/bin/env bash
set -euo pipefail

# Turns off all monitors until the mouse is moved or a key is pressed.

DRY_RUN=false

parse-args() {
    if [[ "${1:-}" == "--dry-run" ]]; then
        DRY_RUN=true
        echo "[dry-run] Display on/off commands will be skipped."
    fi
}

turn-off-screen-in-wayland() {
    # Note on Wayland screen blanking vs. hardware DPMS PowerSaveMode 3:
    # Directly forcing Mutter's hardware DPMS OFF (PowerSaveMode = 3) via D-Bus:
    #   busctl --user set-property org.gnome.Mutter.DisplayConfig /org/gnome/Mutter/DisplayConfig org.gnome.Mutter.DisplayConfig PowerSaveMode i 3
    # was evaluated. However, manually forcing PowerSaveMode 3 in a script requires building and maintaining an 
    # in-script input listener to detect keyboard/mouse activity and restore PowerSaveMode to 0 (ON), which is unnecessarily complex.
    #
    # Instead, this script calls org.gnome.ScreenSaver SetActive b true for clean software blanking.
    # To prevent gsd-power from escalating to hardware DPMS OFF after 10 minutes (which causes an NVIDIA EGL teardown crash),
    # a persistent systemd user service (~/.config/systemd/user/inhibit-idle.service) is used to run:
    #   gnome-session-inhibit --inhibit idle --inhibit-only
    echo "Turning off monitors..."
    if [[ "${XDG_CURRENT_DESKTOP:-}" == *GNOME* ]]; then
        if $DRY_RUN; then
            echo "[dry-run] Would run: busctl --user call org.gnome.ScreenSaver ... SetActive b true"
        else
            busctl --user call org.gnome.ScreenSaver /org/gnome/ScreenSaver org.gnome.ScreenSaver SetActive b true
        fi
    else
        echo "ERROR: Unsupported Wayland Desktop Environment: ${XDG_CURRENT_DESKTOP:-unknown}" >&2
        exit 2
    fi
}

turn-off-screen-in-x11() {
    if $DRY_RUN; then
        echo "[dry-run] Would run: xset dpms force off"
    else
        sleep 0.5
        xset dpms force off
    fi
}

main() {
    parse-args "$@"

    if [[ "$XDG_SESSION_TYPE" == "wayland" ]]; then
        turn-off-screen-in-wayland
    else
        turn-off-screen-in-x11
    fi
}

main "$@"
