#!/bin/bash
#
# Open a file in GVim in a new split. Accepts either a plain path or a
# custom URL of the form
#
#     gvim:///path/to/file.txt:42
#
# where the trailing ":42" is an optional line number to jump to.
#
# Unlike vimt this always opens a fresh split: multiple splits of the
# same file are a normal Vim workflow, so there is no dedup here.

set -euo pipefail

# Populated by parse_target from the single command-line argument.
target_file=""
target_line=""

# Split the argument into a file path and (optional) line number.
# Handles both a plain path and a gvim:// URL with a trailing :LINE.
parse_target() {
  # Strip the URL scheme if present; a plain path is left untouched.
  local -r arg="${1#gvim://}"

  # A trailing ":<digits>" is treated as a line number; anything else
  # (e.g. a colon inside the filename) stays part of the path.
  if [[ "$arg" =~ ^(.*):([0-9]+)$ ]]; then
    target_file="${BASH_REMATCH[1]}"
    target_line="${BASH_REMATCH[2]}"
  else
    target_file="$arg"
    target_line=""
  fi
}

# Check if any GVim server is running. If not, start GVim and exit the script.
launch_gvim_and_exit_unless_running() {
  if [[ -z "$(gvim --serverlist 2>/dev/null)" ]]; then
    if [[ -n "$target_line" ]]; then
      gvim "+${target_line}" "$target_file"
    else
      gvim "$target_file"
    fi
    exit 0
  fi
}

main() {
  parse_target "$1"

  launch_gvim_and_exit_unless_running

  # <C-w>n opens a new split window, then load the file into it.
  gvim --remote-send '<C-w>n'
  gvim --remote-silent "$target_file"

  if [[ -n "$target_line" ]]; then
    gvim --remote-send ":${target_line}<CR>"
  fi

  # Raise the GVim window and give it input focus.
  #
  # Known issue: under GNOME Wayland this only raises the window; the
  # compositor refuses to hand keyboard focus to a background process,
  # so the terminal keeps the keyboard. There is no supported CLI fix on
  # native Wayland. Workaround: run GVim under XWayland (start its server
  # with GDK_BACKEND=x11), where foreground() reliably pulls focus.
  gvim --remote-send ':call foreground()<CR>'
}

main "$@"
