#!/usr/bin/env bash

sensors_data=$(sensors -A -j 2>/dev/null)

echo -ne "Time: \t\t\t"
date

echo -ne "CPU governor: \t\t"
cat /sys/devices/system/cpu/cpufreq/policy0/scaling_governor

echo -ne "Energy preference: \t"
cat /sys/devices/system/cpu/cpufreq/policy0/energy_performance_preference

echo -ne "CPU boost disabled: \t"
cat /sys/devices/system/cpu/intel_pstate/no_turbo

echo -ne "CPU current frequency: \t"
cat /sys/devices/system/cpu/cpufreq/policy0/scaling_cur_freq | awk '{ printf "%sMHz\n", int($1/1000) }'

echo -ne "Core temperature: \t"
echo "$sensors_data" | jq --raw-output '."coretemp-isa-0000" | [to_entries | map(select(.key | match("^Core.*";"i"))) | map(.value) | .[] | to_entries | map(select(.key | match(".*_input$";"i"))) | map(.value) | .[]] | add/length | floor | tostring + "°C"'

nvidia_runtime_status=$(cat /sys/bus/pci/devices/0000\:01\:00.0/power/runtime_status)

if [[ -x "/usr/bin/nvidia-smi" && "$nvidia_runtime_status" == "active" ]]; then
  nsmi_data=$(nvidia-smi -q)
  echo -ne "GPU temp / st / pwr: \t"
  echo "$nsmi_data" | grep "GPU Current Temp" | awk '{ printf "%s°C", $5 }'
  echo -n " / "
  echo "$nsmi_data" | grep "Performance State" | awk '{ printf "%s", $4 }'
  echo -n " / "
  echo "$nsmi_data" | grep "Power Draw" | awk '{ printf "%sW", $4 }'
  echo
fi

#nvidia-settings -q GPUCoreTemp -t | head -n1 | awk '{ printf "%s°C", $1 }'
#nvidia-settings -q GPUCurrentPerfLevel -t | head -n1 | awk '{ printf "%s", $1 }'
#nvidia-smi -q -d power | grep 'Power Draw' | awk '{ printf "%sW", $4 }'
#echo

echo -ne "ACPI temperature: \t"
echo "$sensors_data" | jq --raw-output '."acpitz-acpi-0".temp1.temp1_input | tostring + "°C"'

#cat /sys/class/thermal/thermal_zone0/temp | awk '{ print "ACPI temp1: " $1/1000 "°C" }'

echo -ne "PCH temperature: \t"
echo "$sensors_data" | jq --raw-output '."pch_cometlake-virtual-0".temp1.temp1_input | tostring + "°C"'

echo -ne "Wifi temperature: \t"
echo "$sensors_data" | jq --raw-output '."iwlwifi_1-virtual-0".temp1.temp1_input | tostring + "°C"'

echo
echo "Nvidia runtime:"
echo -e "  status: \t\t$nvidia_runtime_status"

echo -ne "  active time: \t\t"
cat /sys/bus/pci/devices/0000\:01\:00.0/power/runtime_active_time

echo -ne "  suspended time: \t"
cat /sys/bus/pci/devices/0000\:01\:00.0/power/runtime_suspended_time
#cat /proc/acpi/bbswitch

echo
echo "Battery discharge info:"
upower -i $(upower -e | grep BAT) | grep --color=never -E "updated|state|energy-rate|time to empty"

echo
ps -axo pid,pcpu,cputime,etime,comm --cumulative --sort -time | head -n6
echo
top -b -n 1 | head -n15
