#!/usr/bin/env bash
set -e

# Automatically escalate to root if not already running as root
if [ "$EUID" -ne 0 ]; then
  exec sudo "$0" "$@"
fi

# Detect user (running under sudo or as normal user)
REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(eval echo "~$REAL_USER")
HOSTNAME=$(hostname)

echo "=== Bootstrapping workstation configuration for user: $REAL_USER ==="
echo "=== Detected Hostname (Node Name): $HOSTNAME ==="

# 1. Install Cinc Client if not installed
if ! command -v cinc-client &> /dev/null && ! command -v chef-client &> /dev/null; then
  echo "Installing Cinc Client..."
  curl -L https://omnitruck.cinc.sh/install.sh | bash
else
  echo "Chef/Cinc Client is already installed."
fi

# Get the absolute directory where this script resides (the chef-repo root)
CHEFREPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# 2. Ensure Chef runtime directories exist in /var with correct permissions
echo "Ensuring Chef runtime directories exist..."
mkdir -p /var/log/chef /var/cache/chef /var/lib/chef/backup /var/run/chef
chmod 0755 /var/log/chef /var/cache/chef /var/lib/chef /var/lib/chef/backup /var/run/chef
chown -R root:root /var/log/chef /var/cache/chef /var/lib/chef /var/run/chef


# 3. Ensure node JSON attributes file exists in nodes/ directory

NODE_FILE="${CHEFREPO_DIR}/nodes/${HOSTNAME}.json"
if [ ! -f "${NODE_FILE}" ]; then
  echo "Creating default node configuration: ${NODE_FILE}"
  mkdir -p "${CHEFREPO_DIR}/nodes"
  cat <<EOF > "${NODE_FILE}"
{
  "run_list": [
    "role[workstation]"
  ]
}
EOF
fi

echo "=== Bootstrap Complete! ==="
echo "You can now run Chef Solo using:"
echo "  ./chef-update"
