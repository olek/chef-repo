#!/usr/bin/env bash
#
# perf-watch-cmd — one-screen power/thermal/runtime snapshot for this laptop.
# Designed to be wrapped in `watch` (see below). Every row is tolerant of absent
# hardware/paths so the same script runs across machines; we deliberately do NOT
# `set -e` for that reason.
#
# Reference commands useful for wrangling nvidia or general power consumption:
#
# * watching nvidia gpu runtime status (active/suspended)
#     watch --interval 5 cat /sys/bus/pci/devices/0000\:01\:00.0/power/runtime_status
#
# * checking on availability/kind of runtime D3 status (d3cold)
#     cat /proc/driver/nvidia/gpus/0000:01:00.0/power
#
# * regenerating ramfs after changing nvidia etc module configuration
#     update-initramfs -u
#
# * regenerating grub setup after changing its config
#     update-initramfs -u
#
# * setting up limiters on nvidia clocks to force it into economy mode
#     nvidia-smi --persistence-mode=1
#     nvidia-smi --lock-gpu-clocks=300,300
#
#     # not supported for Quadro T1000
#     # nvidia-smi --lock-memory-clocks=810,810
#
#     nvidia-smi --application-clocks=810,300
#
# * configuring nvidia gpu for fine grained runtime D3 status in /etc/modprobe.d/nvidia-custom.conf
#     # Work around broken D3 support in pre-ampere (turing) architecture.
#     # Requires using closed source nvidia driver (nvidia-open does not seem to support rtd3 on turing at all).
#     options nvidia "NVreg_EnableGpuFirmware=0"
#     # Forcing 0x02 'fine' D3 control that is supported on closed source nvidia driver.
#     options nvidia "NVreg_DynamicPowerManagement=0x02"
#
# * Note: current reverse-prime configuration on severus requires a reboot after HDMI port was disconnected for nvidia
#   to go to D3Cold state, but NO configuration changes seems to be necessary. And re-plugging HDMI will automatically
#   activate nvidia gpu. Not bad.

readonly NVIDIA_PCI="0000:01:00.0"
readonly NVIDIA_DEV="/sys/bus/pci/devices/${NVIDIA_PCI}"
readonly NVIDIA_GPU_NAME_FILE="/tmp/nvidia-gpu-name.txt"
readonly VERSIONS_FILE="/tmp/perf-watch-versions.txt"

# Populated once in main() and read by the temperature rows.
sensors_data=""
nvidia_runtime_status=""

# Cache the GPU make/model + loaded driver version so we don't poke lspci (and
# risk waking a suspended GPU) on every refresh.
cache_nvidia_gpu_name() {
  [[ -f "$NVIDIA_GPU_NAME_FILE" ]] && return

  local gpu_name driver_version flavor_str mod_path
  gpu_name=$(lspci | grep '^01:00.0' | sed -e 's/^01:00.0 VGA compatible controller: //')
  # Loaded-module version (e.g. 580.159.03); does not wake a suspended GPU.
  driver_version=$(cat /sys/module/nvidia/version 2>/dev/null)

  if [[ -n "$driver_version" ]]; then
    flavor_str=""
    if grep -iq "open" /proc/driver/nvidia/version 2>/dev/null; then
      flavor_str="open, "
    fi
    mod_path=$(modinfo -F filename nvidia 2>/dev/null)
    if [[ "$mod_path" == */dkms/* ]]; then
      flavor_str="${flavor_str}dkms"
    else
      flavor_str="${flavor_str}non-dkms"
    fi
    echo "$gpu_name / $driver_version ($flavor_str)" > "$NVIDIA_GPU_NAME_FILE"
  else
    echo "$gpu_name / " > "$NVIDIA_GPU_NAME_FILE"
  fi
}

print_time() {
  printf 'Time: \t\t\t'
  date | sed -e 's/\W\W\+/ /'
}

print_computer() {
  printf 'Computer: \t\t'
  cat /sys/devices/virtual/dmi/id/{sys_vendor,product_family} | tr '\n' ' '
  printf '/ '
  grep 'model name' /proc/cpuinfo | head -n1 | sed -e 's/^model name\t\+: //'
}

# OS / kernel / display-server / desktop versions. Sourced from os-release so it
# tracks across releases; values joined by " / ", keys enumerated in parens like
# the "Other temps" line. Robust to a missing session env (watch/sudo) by asking
# loginctl, and degrades to "?" rather than printing blanks.
#
# Every value here is fixed for the life of a boot, so the line is computed once
# and cached. /tmp is tmpfs (cleared on reboot), so the cache self-invalidates
# exactly when a value could change (new kernel, distro upgrade, session switch).
cache_versions() {
  [[ -f "$VERSIONS_FILE" ]] && return

  (
    . /etc/os-release 2>/dev/null
    local os code kernel disp de gnome_ver session
    os="${NAME:-?} ${VERSION%% *}"
    code="${VERSION_CODENAME:-?}"
    kernel=$(uname -r)

    disp="$XDG_SESSION_TYPE"
    if [[ -z "$disp" ]]; then
      session=$(loginctl list-sessions --no-legend 2>/dev/null | awk 'NR==1{print $1}')
      disp=$(loginctl show-session "$session" -p Type --value 2>/dev/null)
    fi
    disp="${disp:-?}"

    de="${XDG_CURRENT_DESKTOP##*:}"
    gnome_ver=$(gnome-shell --version 2>/dev/null | awk '{print $3}')
    [[ -n "$gnome_ver" ]] && de="$de $gnome_ver"
    de="${de:-?}"

    echo "$os / $code / $kernel / $disp / $de (os/code/kernel/disp/de)"
  ) > "$VERSIONS_FILE"
}

print_versions() {
  printf 'Versions: \t\t'
  cat "$VERSIONS_FILE"
}

print_governor() {
  local gov pref
  gov=$(cat /sys/devices/system/cpu/cpufreq/policy0/scaling_governor)
  pref=$(cat /sys/devices/system/cpu/cpufreq/policy0/energy_performance_preference)
  printf 'Governor / pref: \t%s / %s\n' "$gov" "$pref"
}

print_cpu_boost() {
  printf 'CPU boost disabled: \t'
  cat /sys/devices/system/cpu/intel_pstate/no_turbo
}

print_cpu_avg_freq() {
  printf 'CPU avg freq: \t\t'
  cat /sys/devices/system/cpu/cpufreq/policy*/scaling_cur_freq |
    awk 'BEGIN {sum = 0} { sum += $1 } END { printf "%sMHz\n", int(sum / NR / 1000)}'
}

print_cpu_count_freq() {
  printf 'CPU cnt / frq min,max: \t'
  cat /sys/devices/system/cpu/cpufreq/policy*/scaling_cur_freq |
    awk 'NR==1 {min = max = 0} max < $1 { max = $1 } min == 0 || min > $1 { min = $1 } END { printf "%s / %sMHz / %sMHz\n", NR, int(min / 1000), int(max / 1000)}'
}

print_core_temp() {
  printf 'Core temperature: \t'
  echo "$sensors_data" | jq --raw-output '."coretemp-isa-0000" | [to_entries | map(select(.key | match("^Core.*";"i"))) | map(.value) | .[] | to_entries | map(select(.key | match(".*_input$";"i"))) | map(.value) | .[]] | add/length | floor | tostring + "°C"'
}

print_gpu_temp() {
  [[ -x "/usr/bin/nvidia-smi" && "$nvidia_runtime_status" == "active" ]] || return

  # Targeted query (3 fields, CSV) instead of the full `-q` dump: ~6x cheaper
  # (~30ms vs ~180ms) and avoids parsing 269 lines to use 3. Fields come back as
  # "<temp>, <pstate>, <power> W"; reformat to "<temp>°C / <pstate> / <power>W".
  local gpu
  gpu=$(nvidia-smi --query-gpu=temperature.gpu,pstate,power.draw.instant \
    --format=csv,noheader,nounits 2>/dev/null)
  printf 'GPU temp / st / pwr: \t'
  echo "$gpu" | awk -F', *' '{ printf "%s°C / %s / %sW\n", $1, $2, $3 }'
}

# Generic scan: every sensor chip that exposes a temperature reading, printed on
# one line as "<temp> / <temp> / ...  (<chip>/<chip>/...)". Robust to chips being
# renamed across kernel/driver versions (e.g. pch_cometlake-virtual-0).
# Temperatures are floored to whole degrees (we don't care about the .000).
print_other_temps() {
  printf 'Other temps (°C): \t'
  echo "$sensors_data" | jq --raw-output '
    # Shorten long chip names to a couple of letters. First substring match wins;
    # anything unknown falls back to its first word (up to the first separator).
    def shorten:
      [ ["coretemp","core"], ["pch","pch"], ["acpitz","acpi"], ["acpi","acpi"],
        ["iwlwifi","wifi"], ["nvme","nvme"], ["k10temp","cpu"], ["nouveau","gpu"],
        ["amdgpu","gpu"] ] as $map
      | . as $chip
      | ($chip | ascii_downcase) as $lc
      | ([$map[] | . as $p | select($lc | contains($p[0])) | $p[1]] | first)
        // ($chip | split("[-_]"; "") | .[0]);
    [ to_entries[]
      | .key as $chip
      # coretemp is already shown (averaged) on the dedicated Core temperature line.
      | select($chip | ascii_downcase | contains("coretemp") | not)
      | ([.value | to_entries[] | .value | objects | to_entries[]
          | select(.key | test("^temp[0-9]*_input$")) | .value] | first) as $t
      | select($t != null)
      | {key: $chip, label: ($chip | shorten), temp: ($t | floor)} ]
    # Number repeated labels (e.g. two NVMe drives -> nvme1 / nvme2), numbering by
    # original chip key so the suffix is stable. Singletons keep their bare label.
    | ( group_by(.label)
        | map( (sort_by(.key)) as $g
               | if length > 1
                 then ($g | to_entries | map(.value + {label: (.value.label + (.key + 1 | tostring))}))
                 else $g end )
        | flatten )
    | sort_by(.label)
    | "\([.[].temp | tostring] | join(" / ")) (\([.[].label] | join("/")))"'
}

print_nvidia_runtime() {
  printf 'Nvidia runtime for:\t'
  cat "$NVIDIA_GPU_NAME_FILE"

  printf '  status: \t\t%s\n' "$nvidia_runtime_status"

  printf '  D3 allowed / pstate:\t'
  cat "${NVIDIA_DEV}/d3cold_allowed" | tr -d '\n'
  printf ' / '
  cat "${NVIDIA_DEV}/power_state"

  printf '  active time: \t\t'
  cat "${NVIDIA_DEV}/power/runtime_active_time"

  printf '  suspended time: \t'
  cat "${NVIDIA_DEV}/power/runtime_suspended_time"
}

print_battery() {
  printf 'Battery discharge info as of: '
  upower -i "$(upower -e | grep BAT)" |
    grep --color=never -E "updated|state|energy-rate|time to empty" |
    sed -e 's/ \+updated: \+//'
}

print_memory() {
  free -h --wide | awk 'NR<=2'
}

# Cumulative CPU *time* — processes ranked by total CPU consumed over their whole
# lifetime (--cumulative folds in dead children). Answers "what has burned the
# most CPU since it started", which is orthogonal to the instantaneous view below.
print_cumulative_cpu() {
  printf 'Top cumulative CPU time:\n'
  ps -axo pid,pcpu,cputime,etime,comm --cumulative --sort -time | head -n6
}

# Who is eating CPU *right now*. We deliberately avoid both `top` (heavyweight,
# ~250ms, draws a full screen we'd trim away) and plain `ps` (its %CPU is a
# lifetime average, so a process that was busy hours ago still ranks high).
# pidstat samples /proc over a 1s interval, giving true instantaneous %CPU; we
# sort by it and keep the busiest handful. Cost is the 1s sample, not CPU work.
print_busy_processes() {
  printf 'Top instantaneous CPU (%% over 1s):\n'
  # S_TIME_FORMAT=ISO forces a single-token HH:MM:SS timestamp; otherwise a
  # locale's AM/PM splits the time column and shifts every field. We match only
  # real per-second rows on that timestamp in $1, which also drops the trailing
  # "Average:" summary block and the header. Columns: PID=$3, %CPU=$8, and the
  # command ($10..$NF). -l gives the full command line instead of just the comm
  # name; we strip the leading path so $10 "/snap/.../firefox -foo" shows as
  # "firefox -foo", then truncate to 80 chars so one busy process can't blow up
  # the line (and more of the args survive once the path is gone). The owner is
  # pidstat's numeric UID ($2), resolved to a name via a passwd map built once in
  # BEGIN; dynamic snap/service UIDs with no entry fall back to the number.
  S_TIME_FORMAT=ISO pidstat -l 1 1 2>/dev/null |
    awk 'BEGIN { while (("getent passwd" | getline line) > 0) {
                   split(line, f, ":"); user[f[3]] = f[1] } }
         $1 ~ /^[0-9]+:[0-9]+:[0-9]+$/ && $8+0 > 0 {
           sub(/.*\//, "", $10)
           cmd = $10; for (i = 11; i <= NF; i++) cmd = cmd " " $i
           if (length(cmd) > 80) cmd = substr(cmd, 1, 79) "…"
           owner = ($2 in user) ? user[$2] : $2
           if (length(owner) > 12) owner = substr(owner, 1, 11) "…"
           printf "%7s  %-12s  %3d%%  %s\n", $3, owner, $8 + 0.5, cmd
         }' |
    sort -k3 -rn |
    head -n6
}

main() {
  sensors_data=$(sensors -A -j 2>/dev/null)
  nvidia_runtime_status=$(cat "${NVIDIA_DEV}/power/runtime_status")

  cache_nvidia_gpu_name
  cache_versions

  print_time
  print_computer
  print_versions
  print_governor
  print_cpu_boost
  print_cpu_avg_freq
  print_cpu_count_freq
  print_core_temp
  print_gpu_temp
  print_other_temps
  echo
  print_nvidia_runtime
  echo
  print_battery
  echo
  print_memory
  echo
  print_cumulative_cpu
  echo
  print_busy_processes
}

main "$@"
