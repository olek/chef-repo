  " relative path (src/foo.txt)
  nnoremap <leader>cpr :let @+=expand("%")<CR>

  " absolute path (/something/src/foo.txt)
  nnoremap <leader>cpa :let @+=expand("%:p")<CR>

  " filename (foo.txt)
  nnoremap <leader>cpn :let @+=expand("%:t")<CR>

  " short filename (foo)
  nnoremap <leader>cps :let @+=expand("%:t:r")<CR>

  " directory name (/something/src)
  nnoremap <leader>cpd :let @+=expand("%:p:h")<CR>
endif

