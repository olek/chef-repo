set -g prefix `
bind-key ` send-prefix

# integration with tmuxstart
bind S command-prompt -p "Make/attach session:" "new-window 'tmuxstart \'%%\''"

# Set the internal terminal type
set -g default-terminal "tmux-256color"

# Tell tmux your outer terminal (e.g., xterm-256color) supports true color (Tc/RGB)
set -as terminal-features ",xterm-256color:RGB"

# Turn on hyperlinks support for tmux that is disabled by default
set -as terminal-features ",*:hyperlinks"

# Set that silly Esc-Wait off, so VI works again properly
set-option -sg  escape-time 0

# lighten the BG color of status bar to make it easier to read
#set -g status-bg brightgreen
set -g status-style bg=colour81

# Default history limit 2000 lines is too low.
set-option -g history-limit 100000

# Vi movement keys (jkhl) work in copy mode
set-window-option -g mode-keys vi

# No time in status line, please (freaks out tabs on some terminals)
# set -g status-right '#S:#W #H'

# Actually disable right status info, it is not not helpful and just adds noise
set -g status-right ''

# Reserve more space for longer session names on the left status line
set -g status-left-length 25
