#PS1="${debian_chroot:+($debian_chroot)}\[\e[01;32m\]\u@\h\[\e[00m\]: \`short_dir\` \$\[\e[0m\] "
# NOTE: $__short_dir is populated by PROMPT_COMMAND in 31-history.
# We deliberately avoid embedding $(short_dir) / `short_dir` directly in PS1:
# command substitution inside PS1 confuses readline's column tracking once the
# expanded prompt nears $COLUMNS, causing line-editing glitches (especially in
# vi mode) when cd'd into long directory names. Computing it once per prompt
# via PROMPT_COMMAND and referencing the variable here sidesteps that.
#PS1='\[\e[01;32m\]${__short_dir}\[\e[0m\] \$ '
PS1='\[\e[38;5;25m\]${__short_dir}\[\e[0m\] \$ '

