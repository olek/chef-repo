#!/usr/bin/env bash
set -e

# Automatically escalate to root if not already running as root
if [ "$EUID" -ne 0 ]; then
  exec sudo "$0" "$@"
fi

# Detect user (running under sudo or as normal user)
REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME=$(eval echo "~$REAL_USER")
HOSTNAME=$(hostname)

echo "=== Bootstrapping workstation configuration for user: $REAL_USER ==="
echo "=== Detected Hostname (Node Name): $HOSTNAME ==="

# 1. Install Cinc Client if not installed
if ! command -v cinc-client &> /dev/null && ! command -v chef-client &> /dev/null; then
  echo "Installing Cinc Client..."
  curl -L https://omnitruck.cinc.sh/install.sh | bash
else
  echo "Chef/Cinc Client is already installed."
fi

# Get the absolute directory where this script resides (the chef-repo root)
CHEFREPO_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# 2. Setup config directories
echo "Configuring /etc/chef..."
mkdir -p /etc/chef

# 3. Create solo.rb config from template
echo "Generating /etc/chef/solo.rb from template..."
ruby -rerb -e '
  class Node
    def [](key)
      key == :hostname ? "'"${HOSTNAME}"'" : nil
    end
  end
  node = Node.new

  module Chef
    Config = { cookbook_path: ["'"${CHEFREPO_DIR}"'/cookbooks"] }
  end

  template = File.read("'"${CHEFREPO_DIR}"'/cookbooks/woodenbits/templates/default/system/etc/chef/solo.rb.erb")
  erb = ERB.new(template)
  puts erb.result(binding)
' > /etc/chef/solo.rb

# 4. Create solo-attributes.json if not present
if [ ! -f /etc/chef/solo-attributes.json ]; then
  cat <<EOF > /etc/chef/solo-attributes.json
{
  "run_list": [
    "role[workstation]"
  ]
}
EOF
fi

echo "=== Bootstrap Complete! ==="
echo "You can now run Chef Solo using:"
echo "  ./chef-update"
